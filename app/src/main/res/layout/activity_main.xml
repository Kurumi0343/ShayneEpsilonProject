<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="8dp"
    android:orientation="vertical"
    tools:context=".MainActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:orientation="vertical"
        android:background="@drawable/rectanngle_stroke">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/statusnetworktype"
                android:textColor="@color/white"
                android:text="NO DATA"
                android:singleLine="true"
                android:paddingLeft="7dp"
                android:textSize="11dp"
                android:paddingRight="2dp"
                android:layout_weight="1"
                android:gravity="center_vertical"/>
            <TextView
                android:layout_width="120dp"
                android:layout_height="match_parent"
                android:textColor="@color/white"
                android:text="EPSILON"
                android:textStyle="bold|italic"
                android:singleLine="true"
                android:gravity="center_vertical|center_horizontal"/>
            <TextView
                android:layout_width="70dp"
                android:textSize="11dp"
                android:layout_height="match_parent"
                android:singleLine="true"
                android:textColor="@color/white"
                android:id="@+id/statusnetworkspeed"
                android:text="0ms"
                android:gravity="center_vertical|center_horizontal"/>
            <TextView
                android:layout_width="70dp"
                android:textSize="11dp"
                android:singleLine="true"
                android:layout_height="match_parent"
                android:textColor="@color/white"
                android:id="@+id/statusbatterytemperature"
                android:text="40°C"
                android:gravity="center_vertical|center_horizontal"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textColor="@color/white"
                    android:text="60"
                    android:id="@+id/statusdevicefps"
                    android:gravity="center_horizontal|center_vertical"
                    android:textSize="60dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textColor="@color/white"
                    android:text="fps"
                    android:gravity="center_horizontal|center_vertical"
                    android:textSize="15dp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_weight="1"
        android:gravity="bottom">
        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:id="@+id/startactivity"
            android:background="@drawable/rectanngle_stroke"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="25dp"
            android:text="START"
            android:textColor="@color/white"
            android:textSize="21dp"
            />
        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="140dp"
            android:layout_height="60dp"
            android:id="@+id/exitactivity"
            android:background="@drawable/rectanngle_stroke"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="25dp"
            android:text="EXIT"
            android:textColor="@color/white"
            android:textSize="21dp"
            />
    </LinearLayout>
</LinearLayout>